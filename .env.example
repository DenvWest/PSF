# Site
NEXT_PUBLIC_SITE_URL=https://perfectsupplement.nl

# Supabase (publiek voor client waar nodig)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key

# Server-only: intake & tabellen zonder browser-toegang
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# B2B tenant: UUID van de organisatie (nu default PerfectSupplement)
ORGANIZATION_ID=00000000-0000-0000-0000-000000000001
# HMAC voor HttpOnly intake-sessiecookies (min. 32 random bytes)
COOKIE_SECRET=your_long_random_secret

# Cloudflare Turnstile (NEXT_PUBLIC + secret; zelfde widget als contact)
NEXT_PUBLIC_TURNSTILE_SITE_KEY=your_site_key
TURNSTILE_SECRET_KEY=your_secret_key

# Contact form (kopieer naar .env.local — .env.local niet committen)
# Zet CONTACT_SMTP_DISABLED=true om lokaal zonder externe call te testen.
CONTACT_SMTP_DISABLED=false

# Primair: Zoho CRM
ZOHO_CLIENT_ID=your_zoho_client_id
ZOHO_CLIENT_SECRET=your_zoho_client_secret
ZOHO_REFRESH_TOKEN=your_zoho_refresh_token
ZOHO_ACCOUNTS_DOMAIN=https://accounts.zoho.eu
ZOHO_API_DOMAIN=https://www.zohoapis.eu
ZOHO_CRM_MODULE=Leads

# Fallback/legacy: SMTP
OUTBOX_EMAIL=youroutboxemail@example.com
OUTBOX_EMAIL_PASSWORD=yourpassword
INBOX_EMAIL=yourinboxemail@example.com
SMTP_HOST=smtp.zoho.com
SMTP_PORT=465
SMTP_SECURE=true

# Comma-separated list of IPs to exempt from rate limiting
# Useful for development, testing and trusted admins
# Example: RATE_LIMIT_WHITELIST=83.85.206.38,198.51.100.7
RATE_LIMIT_WHITELIST=
