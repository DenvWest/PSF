# Site
NEXT_PUBLIC_SITE_URL=https://perfectsupplement.nl

# Contact form / Zoho CRM (kopieer naar .env.local — .env.local niet committen)
# Zet CONTACT_SMTP_DISABLED=true om lokaal zonder externe call te testen.
CONTACT_SMTP_DISABLED=false
ZOHO_CLIENT_ID=your_zoho_client_id
ZOHO_CLIENT_SECRET=your_zoho_client_secret
ZOHO_REFRESH_TOKEN=your_zoho_refresh_token
ZOHO_ACCOUNTS_DOMAIN=https://accounts.zoho.eu
ZOHO_API_DOMAIN=https://www.zohoapis.eu
ZOHO_CRM_MODULE=Leads
